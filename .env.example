# .env.example
# 실제 값은 .env 에 채우고 git 에 올리지 마십시오 (.gitignore 처리됨).
# GitHub Actions 에서는 동일 키를 repository secrets 로 등록.

# ─────────────────────────────────────────
# Brave Search API (3위일체 검색)
# ─────────────────────────────────────────
# 발급: https://api-dashboard.search.brave.com/ → Subscribe to Free plan → API Keys → "Add API Key"
# Free quota: 월 2,000 calls (우리 케이스 일 5 × 30 = 150 호출 → 13배 여유)
# 카드 등록은 요구하지만 quota 초과 시 자동 차단이라 청구 0.
# 매체 화이트리스트는 코드의 sources.yaml 이 site: filter 로 쿼리에 주입.
BRAVE_SEARCH_API_KEY=your-brave-search-api-key

# ─────────────────────────────────────────
# Gemini API (통합 요약 + 한국어 번역)
# ─────────────────────────────────────────
# 발급: https://aistudio.google.com/app/apikey
# 모델: gemini-2.x flash 권장 (무료 tier 충분)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────
# Gmail SMTP (구독자 일괄 발송)
# ─────────────────────────────────────────
# 발급: Gmail 계정 2FA 활성화 후 https://myaccount.google.com/apppasswords 에서 16자리 앱 비밀번호 생성
GMAIL_USER=your-sender@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# ─────────────────────────────────────────
# Supabase (Postgres 무료 tier — articles / subscribers / runs / scrape_enabled)
# ─────────────────────────────────────────
# 발급: https://supabase.com/ → 프로젝트 생성 → Settings → API
# SERVICE_ROLE_KEY 는 절대 클라이언트에 노출 금지 (RLS 우회 권한)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# 같은 프로젝트에 다른 서비스가 들어와도 격리되도록 별도 schema 사용.
# 마이그레이션 0001 이 ai_news schema 를 만들고 4 테이블을 거기에 둡니다.
# Dashboard → Settings → API → "Exposed schemas" 에 ai_news 추가 필요.
SUPABASE_SCHEMA=ai_news

# ─────────────────────────────────────────
# Admin 페이지 단순 인증 토큰
# ─────────────────────────────────────────
# 임의의 긴 랜덤 문자열. `openssl rand -hex 32` 같은 걸로 생성.
ADMIN_TOKEN=replace-with-random-hex-token
# 로컬 전용 (127.0.0.1) 으로만 쓸 거면 false 로 두면 인증 팝업 안 뜸.
# 외부에서 접근 가능한 환경 (서버 배포 등) 이면 반드시 true.
ADMIN_AUTH_ENABLED=true

# ─────────────────────────────────────────
# 운영 설정
# ─────────────────────────────────────────
# 발송 직전 dry-run 으로 멈출지 (true 면 메일 발송 skip)
DRY_RUN=false
# 발송 시각 라벨 (메일 제목에 들어감, KST 기준 표시용)
DIGEST_TZ=Asia/Seoul
